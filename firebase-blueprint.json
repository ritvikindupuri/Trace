{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SimulationHistory": {
      "title": "Simulation History",
      "description": "Stores the results and logs of a completed simulation run.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "scenario_id": { "type": "string" },
        "scenario_name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "events": { "type": "string", "description": "JSON stringified events" },
        "attackLogs": { "type": "string", "description": "JSON stringified logs" },
        "gaps": { "type": "string", "description": "JSON stringified gaps" }
      },
      "required": ["uid", "scenario_id", "timestamp"]
    },
    "CustomScenario": {
      "title": "Custom Scenario",
      "description": "User-defined attack scenarios.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "steps": { "type": "string", "description": "JSON stringified steps" }
      },
      "required": ["uid", "id", "name"]
    },
    "AppNotification": {
      "title": "Notification",
      "description": "System or threat notifications.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Recipient UID" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "threat", "success"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["uid", "title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/simulations/{simulationId}": {
      "schema": "SimulationHistory",
      "description": "History of simulation runs."
    },
    "/customScenarios/{scenarioId}": {
      "schema": "CustomScenario",
      "description": "User created scenarios."
    },
    "/notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "User notifications."
    }
  }
}
